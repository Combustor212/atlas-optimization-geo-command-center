# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Google Search Console (for future GSC API integration)
# GSC_CLIENT_ID=
# GSC_CLIENT_SECRET=
# GSC_REFRESH_TOKEN=

# Optional: Google Analytics 4
# GA4_PROPERTY_ID=
# GA4_CLIENT_EMAIL=
# GA4_PRIVATE_KEY=

# Optional: Local Falcon rank tracking
# LOCAL_FALCON_API_KEY=

# AGS Leads Funnel (REQUIRED for scan/contact/call leads from AGS)
# Generate key: openssl rand -hex 32 (must match AGS_LEADS_API_KEY in MGO backend)
AGS_LEADS_API_KEY=your-secret-api-key-here
# Must match an agency slug in your database (run: SELECT slug FROM agencies)
AGS_LEADS_AGENCY_SLUG=my-agency
