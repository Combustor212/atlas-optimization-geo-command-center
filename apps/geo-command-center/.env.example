# ==============================================================================
# GEO COMMAND CENTER — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# SCAN SYSTEM — REQUIRED for /api/meo/scan to work
# Without these, scans will degrade or fail entirely.
# ------------------------------------------------------------------------------

# Google Places API key (enables place search, place details, competitor fetch)
# Enable "Places API" in Google Cloud Console → APIs & Services → Library
# Must have: Places API (not just Maps JavaScript API)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
# Alias — set either GOOGLE_MAPS_API_KEY or GOOGLE_PLACES_API_KEY (or both)
# GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# OpenAI API key (enables GEO AI Visibility scoring via gpt-4o)
# Without this, GEO score defaults to the MEO score (no AI analysis)
OPENAI_API_KEY=sk-...

# ------------------------------------------------------------------------------
# SUPABASE — REQUIRED for dashboard, auth, and lead capture
# ------------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — used server-side only for lead writes and admin queries
# Find in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------------------------------------
# AGS LEADS FUNNEL — REQUIRED for scan/contact/call leads from AGS frontend
# ------------------------------------------------------------------------------

# Shared secret between Geo Command Center and MGO backend / AGS frontend
# Generate: openssl rand -hex 32
# Must match AGS_LEADS_API_KEY in:
#   - apps/MGODATAImprovedcursor copy/mgo-scanner-backend/.env
#   - apps/MGODATAImprovedcursor copy/mgodataImprovedthroughcursor/.env.local (VITE_AGS_LEADS_API_KEY)
AGS_LEADS_API_KEY=your-secret-api-key-here

# Agency slug for scan leads — must exist in Supabase agencies table
# Check: SELECT slug FROM agencies; (default created during setup is "my-agency")
AGS_LEADS_AGENCY_SLUG=my-agency

# Resend — scan result emails fired from /api/meo/scan and /api/scan
# Get from: resend.com → API Keys (verify a sending domain first)
# RESEND_API_KEY=re_...
# SCAN_ADMIN_EMAIL=info@atlasgrowths.com        # defaults to info@atlasgrowths.com
# NEXT_PUBLIC_BOOKING_URL=https://atlasgrowths.com/get-support?book=1

# TikTok Events API (server-side) — optional; POST /api/leads fires SubmitForm when set
# Token: TikTok Events Manager → Settings → Generate access token
# TIKTOK_TEST_EVENT_CODE: Events Manager → Test Events tab (e.g. TEST18286). Omit in production.
# TIKTOK_PIXEL_CODE defaults to AGS web pixel if unset.
# TIKTOK_EVENTS_ACCESS_TOKEN=
# TIKTOK_PIXEL_CODE=D7JADEJC77UDQGOITQOG
# TIKTOK_TEST_EVENT_CODE=TEST18286

# ------------------------------------------------------------------------------
# STRIPE — REQUIRED for billing/subscription features
# ------------------------------------------------------------------------------

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------------------
# OPTIONAL INTEGRATIONS
# ------------------------------------------------------------------------------

# Google Search Console (future GSC API integration)
# GSC_CLIENT_ID=
# GSC_CLIENT_SECRET=
# GSC_REFRESH_TOKEN=

# Google Analytics 4
# GA4_PROPERTY_ID=
# GA4_CLIENT_EMAIL=
# GA4_PRIVATE_KEY=

# Local Falcon rank tracking
# LOCAL_FALCON_API_KEY=
