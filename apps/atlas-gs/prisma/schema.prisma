// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TEAM
}

enum BusinessStatus {
  LEAD
  PROSPECT
  ACTIVE
  PAUSED
  CHURNED
}

enum DealStage {
  LEAD
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum WorkItemCategory {
  SEO
  GEO
  MEO
  CRM
  WEBSITE
  ALL_SERVICES
  ADMIN
}

enum WorkItemStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum WorkItemPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id               String   @id @default(cuid())
  name             String?
  email            String   @unique
  password         String   // Legacy - auth now via Supabase
  supabaseUserId   String?  @unique @map("supabase_user_id") // Links to Supabase auth.users
  role             UserRole @default(TEAM)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assignedWorkItems WorkItem[]
  activityLogs      ActivityLog[]

  @@map("users")
}

model Business {
  id                   String         @id @default(cuid())
  name                 String
  legalName            String?
  industry             String?
  website              String?
  address              String?
  city                 String?
  state                String?
  zip                  String?
  primaryContactName   String?
  primaryContactEmail  String?
  primaryContactPhone  String?
  notes                String?
  status               BusinessStatus @default(LEAD)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  deals         Deal[]
  contracts     Contract[]
  invoices      Invoice[]
  workItems     WorkItem[]
  activityLogs  ActivityLog[]

  @@map("businesses")
}

model Deal {
  id              String     @id @default(cuid())
  businessId      String
  stage           DealStage  @default(LEAD)
  expectedMrr     Int?       // in cents
  expectedSetupFee Int?      // in cents
  closeDate       DateTime?
  source          String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  business  Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contracts Contract[]

  @@map("deals")
}

model Contract {
  id                 String         @id @default(cuid())
  businessId         String
  dealId             String?
  startDate          DateTime
  endDate            DateTime
  termMonths         Int
  autoRenew          Boolean        @default(false)
  renewalNoticeDays  Int            @default(30)
  status             ContractStatus @default(DRAFT)
  mrr                Int            @default(0) // in cents
  setupFee           Int            @default(0) // in cents
  
  // Services included (simple boolean flags)
  serviceSEO         Boolean        @default(false)
  serviceGEO         Boolean        @default(false)
  serviceMEO         Boolean        @default(false)
  serviceCRM         Boolean        @default(false)
  serviceWEBSITE     Boolean        @default(false)
  
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  deal       Deal?      @relation(fields: [dealId], references: [id], onDelete: SetNull)
  invoices   Invoice[]
  workItems  WorkItem[]

  @@map("contracts")
}

model Invoice {
  id             String        @id @default(cuid())
  businessId     String
  contractId     String?
  invoiceNumber  String        @unique
  issueDate      DateTime
  dueDate        DateTime
  amountCents    Int
  currency       String        @default("USD")
  status         InvoiceStatus @default(DRAFT)
  paidAt         DateTime?
  paymentMethod  String?
  paymentLink    String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@map("invoices")
}

model WorkItem {
  id              String           @id @default(cuid())
  businessId      String
  contractId      String?
  title           String
  category        WorkItemCategory
  description     String?
  status          WorkItemStatus   @default(TODO)
  priority        WorkItemPriority @default(MEDIUM)
  dueDate         DateTime?
  assignedToUserId String?
  checklist       Json?            // Array of {text: string, done: boolean}
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contract     Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  assignedTo   User?     @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@map("work_items")
}

model ActivityLog {
  id              String    @id @default(cuid())
  businessId      String?
  entityType      String    // "Business", "Deal", "Contract", "Invoice", "WorkItem"
  entityId        String
  action          String    // "CREATED", "UPDATED", "STATUS_CHANGED", etc.
  message         String
  createdByUserId String
  createdAt       DateTime  @default(now())

  business  Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

