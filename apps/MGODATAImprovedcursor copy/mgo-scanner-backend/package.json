{
  "name": "mgo-scanner-backend",
  "version": "1.0.0",
  "description": "MGO Data Scanner Backend Service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "PORT=3002 tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset --force && npm run db:seed",
    "db:studio": "npx prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "mgo",
    "scanner",
    "meo",
    "geo"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "ioredis": "^5.9.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^10.1.0",
    "openai": "^4.20.0",
    "pg": "^8.16.3",
    "prisma": "^7.2.0",
    "resend": "^6.6.0",
    "stripe": "^20.1.0",
    "swagger-ui-express": "^5.0.1",
    "undici": "^5.28.2",
    "yamljs": "^0.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
