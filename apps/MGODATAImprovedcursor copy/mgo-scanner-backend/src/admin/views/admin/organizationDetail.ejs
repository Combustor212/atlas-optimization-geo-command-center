<div class="header">
  <h1><%= title %></h1>
  <a href="/admin/orgs" class="btn btn-secondary">Back to Organizations</a>
</div>

<div class="content">
  <h2>Organization Details</h2>
  
  <div class="detail-row">
    <div class="detail-label">ID</div>
    <div class="detail-value"><%= org.id %></div>
  </div>
  
  <div class="detail-row">
    <div class="detail-label">Name</div>
    <div class="detail-value"><%= org.name %></div>
  </div>
  
  <div class="detail-row">
    <div class="detail-label">Owner</div>
    <div class="detail-value"><a href="/admin/users/<%= org.owner.id %>"><%= org.owner.email %></a></div>
  </div>
  
  <div class="detail-row">
    <div class="detail-label">Created</div>
    <div class="detail-value"><%= new Date(org.createdAt).toLocaleString() %></div>
  </div>
  
  <h3 style="margin-top: 30px;">Members</h3>
  <table>
    <thead>
      <tr>
        <th>User</th>
        <th>Role</th>
      </tr>
    </thead>
    <tbody>
      <% org.members.forEach(member => { %>
      <tr>
        <td><a href="/admin/users/<%= member.user.id %>"><%= member.user.email %></a></td>
        <td><span class="badge badge-info"><%= member.role %></span></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  
  <h3 style="margin-top: 30px;">Locations</h3>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>City</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% org.locations.forEach(location => { %>
      <tr>
        <td><a href="/admin/locations/<%= location.id %>"><%= location.name %></a></td>
        <td><%= location.city || '-' %></td>
        <td><%= new Date(location.createdAt).toLocaleDateString() %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  
  <h3 style="margin-top: 30px;">Recent Scans</h3>
  <table>
    <thead>
      <tr>
        <th>Scan ID</th>
        <th>Location</th>
        <th>Status</th>
        <th>Score</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% org.scans.forEach(scan => { %>
      <tr>
        <td><a href="/admin/scans/<%= scan.id %>"><%= scan.id.substring(0, 12) %>...</a></td>
        <td><%= scan.locationId %></td>
        <td><span class="badge badge-<%= scan.status === 'COMPLETE' ? 'success' : scan.status === 'FAILED' ? 'danger' : 'warning' %>"><%= scan.status %></span></td>
        <td><%= scan.scoreOverall || '-' %></td>
        <td><%= new Date(scan.createdAt).toLocaleDateString() %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>



