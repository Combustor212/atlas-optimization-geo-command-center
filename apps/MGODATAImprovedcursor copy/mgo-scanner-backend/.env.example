# Copy to .env and fill in your values: cp .env.example .env

# Database
# DATABASE_URL=postgresql://user:password@localhost:5432/mgo_production?schema=public

# JWT
# JWT_SECRET=your-64-byte-hex-secret
# JWT_EXPIRES_IN=7d

# APIs
# GOOGLE_PLACES_API_KEY=
# OPENAI_API_KEY=
# RESEND_API_KEY=
# ENCRYPTION_MASTER_KEY=

# AGS Leads → Geo Command Center (REQUIRED for scan/contact/call leads to flow)
# Generate key: openssl rand -hex 32 (must match AGS_LEADS_API_KEY in Geo Command Center)
AGS_LEADS_API_KEY=your-secret-api-key-here
# Local: http://localhost:3000  |  Production: https://your-geo-command-center.vercel.app
GEO_COMMAND_CENTER_URL=http://localhost:3000
