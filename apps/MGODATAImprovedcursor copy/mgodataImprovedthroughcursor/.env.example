# AGS Frontend - Copy to .env.local: cp .env.example .env.local
# Vite embeds these at build time (VITE_ prefix required)

# =============================================================================
# API URLs (REQUIRED for scans and leads to flow to Geo Command Center)
# =============================================================================

# Scan API base URL - where POST /api/meo/scan and /api/geo/* are hosted
# Local dev: leave empty (Vite proxy forwards /api to localhost:3000)
# Production: BASE URL only, e.g. https://admin.atlasgrowths.com (NOT .../api/meo/scan)
# If you set a full path by mistake, we normalize to origin automatically.
VITE_API_URL=

# Geo Command Center - for Book a Call slots, scheduling, and direct lead submit
# Local: http://localhost:3000  |  Production: https://admin.atlasgrowths.com
VITE_GEO_COMMAND_CENTER_URL=http://localhost:3000

# Optional: If set, contact/call forms submit directly to Geo (bypasses MGO)
# Must match AGS_LEADS_API_KEY in Geo Command Center
# VITE_AGS_LEADS_API_KEY=

# =============================================================================
# Other (if needed)
# =============================================================================
# VITE_BACKEND_URL=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
