{
  "name": "atlas-optimization-geo-command-center",
  "version": "1.0.0",
  "private": true,
  "description": "GEO Command Center + Atlas GS - Agency dashboards and CRM",
  "workspaces": [
    "apps/geo-command-center",
    "apps/atlas-gs"
  ],
  "scripts": {
    "dev:geo": "PORT=3000 npm run dev --workspace=apps/geo-command-center",
    "dev:geo:fresh": "rm -rf apps/geo-command-center/.next && PORT=3000 npm run dev --workspace=apps/geo-command-center",
    "dev:atlas": "npm run dev --workspace=apps/atlas-gs",
    "dev:mgo-backend": "cd \"apps/MGODATAImprovedcursor copy/mgo-scanner-backend\" && npm run dev",
    "dev:mgo-frontend": "cd \"apps/MGODATAImprovedcursor copy/mgodataImprovedthroughcursor\" && npm run dev",
    "build:geo": "npm run build --workspace=apps/geo-command-center",
    "build:atlas": "npm run build --workspace=apps/atlas-gs",
    "build:mgo": "cd \"apps/MGODATAImprovedcursor copy/mgodataImprovedthroughcursor\" && npm run build"
  }
}
